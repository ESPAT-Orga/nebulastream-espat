CREATE SINK sinkStream(stream.statisticStart UINT64 NOT NULL, stream.statisticEnd UINT64 NOT NULL, stream.binStart UINT64 NOT NULL, stream.binCounter UINT64 NOT NULL, stream.binEnd UINT64 NOT NULL) TYPE File;
CREATE SINK sinkStreamBuild(stream.statisticId UINT64 NOT NULL, stream.statisticStart UINT64 NOT NULL, stream.statisticEnd UINT64 NOT NULL, stream.statisticNumberOfSeenTuples UINT64 NOT NULL) TYPE File;

# Solely build operator
# equi width histogram arguments:
# - statistic id to write to,
# - field to build the histogram over,
# - number of buckets,
# - minValue,
# - maxValue and
# - datatype of the counter (as lowercase NES datatype)
SELECT EQUIWIDTHHISTOGRAM(44, value, 5, 0, 25, uint64) FROM stream WINDOW TUMBLING(timestamp, size 5 sec) INTO sinkStreamBuild;
----
44 0 5000 11
44 10000 15000 5
44 15000 20000 5
44 20000 25000 2
44 5000 10000 5

# Simple equi width histogram
# histogram probe arguments: (Stat Hash we want to retrieve from statStore, datatype of counter, datatype of startEnd)
SELECT statisticStart, statisticEnd, binStart, binCounter, binEnd FROM (
    SELECT EQUIWIDTHHISTOGRAM_PROBE(45, uint64, uint64)
    FROM (
        SELECT EQUIWIDTHHISTOGRAM(45, value, 5, 0, 25, uint64) FROM stream WINDOW TUMBLING(timestamp, size 5 sec)
    )
) INTO sinkStream;
----
0 5000 0 11 5
0 5000 5 0 10
0 5000 10 0 15
0 5000 15 0 20
0 5000 20 0 25
5000 10000 0 0 5
5000 10000 5 5 10
5000 10000 10 0 15
5000 10000 15 0 20
5000 10000 20 0 25
