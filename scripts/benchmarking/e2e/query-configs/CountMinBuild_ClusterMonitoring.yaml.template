query: SELECT COUNTMINSKETCH({statistic_id}, userId, {rows}, {columns}, {counter_type}, 42) FROM build_source WINDOW TUMBLING(creationTS, size {window_size} sec) INTO void_sink;
sinks:
  - name: void_sink
    schema:
      - name: build_source$statisticid
        type: UINT64
      - name: build_source$statisticstart
        type: UINT64
      - name: build_source$statisticend
        type: UINT64
      - name: build_source$statisticnumberofseentuples
        type: UINT64
    type: Void
    config:
      file_path: "/tmp/discard_build_sink.csv"
    parser_config: {{ }}
logical:
  - name: build_source
    schema:
      - name: creationTS
        type: UINT64
      - name: jobId
        type: UINT64
      - name: taskId
        type: UINT64
      - name: machineId
        type: INT64
      - name: eventType
        type: INT16
      - name: userId
        type: INT16
      - name: category
        type: INT16
      - name: priority
        type: INT16
      - name: cpu
        type: FLOAT64
      - name: ram
        type: FLOAT64
      - name: disk
        type: FLOAT64
      - name: constraints
        type: BOOLEAN
physical:
  - logical: build_source
    type: File
    parser_config:
      type: CSV
    source_config:
      file_path: {build_dataset_path}
