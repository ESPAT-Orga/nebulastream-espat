CREATE SINK sinkStream(stream.statisticStart UINT64 NOT NULL, stream.statisticEnd UINT64 NOT NULL, stream.rowIndex UINT64 NOT NULL, stream.columnIndex UINT64 NOT NULL, stream.counter UINT64 NOT NULL) TYPE File;
CREATE SINK sinkStreamBuild(stream.statisticHash UINT64 NOT NULL, stream.statisticStart UINT64 NOT NULL, stream.statisticEnd UINT64 NOT NULL, stream.statisticNumberOfSeenTuples UINT64 NOT NULL) TYPE File;

# Solely build operator
# WARNING: If you increase the row count, you might also have to increase the countMinAggregationHashMapPageSize in the query execution config!
# arguments: statisticHash, field to estimate, columns, rows, counter datatype, seed for hash functions
SELECT COUNTMINSKETCH(46, value, 9, 4, uint64, 42) FROM stream WINDOW TUMBLING(timestamp, size 5 sec) INTO sinkStreamBuild;
----
46 0 5000 11
46 10000 15000 5
46 15000 20000 5
46 20000 25000 2
46 5000 10000 5

# Simple count min sketch
SELECT statisticStart, statisticEnd, rowIndex, columnIndex, counter FROM (
    SELECT COUNTMIN_PROBE(47, uint64)
    FROM (
        SELECT COUNTMINSKETCH(47, value, 9, 4, uint64, 42) FROM stream WINDOW TUMBLING(timestamp, size 5 sec)
    )
) INTO sinkStream;
