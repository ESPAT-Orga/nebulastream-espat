1,14,14000
1,15,15000
1,16,16000
1,17,17000
1,18,18000
1,19,19000
1,20,20000
1,21,21000

CREATE SINK sinkStream(stream.statisticStart UINT64 NOT NULL, stream.statisticEnd UINT64 NOT NULL, stream.rowIndex UINT64 NOT NULL, stream.columnIndex UINT64 NOT NULL, stream.counter UINT64 NOT NULL) TYPE File;
CREATE SINK sinkStreamBuild(stream.statisticId UINT64 NOT NULL, stream.statisticStart UINT64 NOT NULL, stream.statisticEnd UINT64 NOT NULL, stream.statisticNumberOfSeenTuples UINT64 NOT NULL) TYPE File;

# Solely build operator
# arguments: statisticId, field to estimate, memoryBudget (rows × cols × sizeof(uint64) state)
SELECT COUNTMINSKETCH(46, value, 288) FROM stream WINDOW TUMBLING(timestamp, size 5 sec) INTO sinkStreamBuild;
----
46 0 5000 11
46 10000 15000 5
46 15000 20000 5
46 20000 25000 2
46 5000 10000 5

# Simple count min sketch
SELECT statisticStart, statisticEnd, rowIndex, columnIndex, counter FROM (
    SELECT COUNTMIN_PROBE(47, uint64)
    FROM (
        SELECT COUNTMINSKETCH(47, value, 288) FROM stream WINDOW TUMBLING(timestamp, size 5 sec)
    )
) INTO sinkStream;
