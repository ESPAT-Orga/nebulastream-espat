# name: benchmark_statistic_build/EquiWidthHistogramBuild.test
# description: Benchmark for equiwidth histogram build operator over Nexmark bid data
# groups: [benchmark, large, Synopsis, Aggregation]

CREATE LOGICAL SOURCE bid(timestamp UINT64 NOT NULL, auctionId INT32 NOT NULL, bidder INT32 NOT NULL, price FLOAT64 NOT NULL);
CREATE PHYSICAL SOURCE FOR bid TYPE Memory;
ATTACH FILE large/nexmark/bid_6GB.csv

SELECT EQUIWIDTHHISTOGRAM(200, price, {num_buckets}, {min_value}, {max_value}, {counter_type}) FROM bid WINDOW TUMBLING(timestamp, size 10 sec) INTO Void();
